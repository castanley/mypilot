# =============================================================================
# MyPilot Stack configuration
# Copy to .env (scripts/generate-secrets.sh fills in strong random secrets).
# The .env file is git-ignored. NEVER commit real secrets.
# =============================================================================

# --- Site / reverse proxy -----------------------------------------------------
# Host label used by the app for display/URLs (not for routing).
MYPILOT_SITE_ADDRESS=localhost

# How Caddy serves the panel:
#   :80                 -> plain HTTP for ANY host (LAN default; works via localhost,
#                          127.0.0.1, your LAN IP, Tailscale/MagicDNS names, hostnames)
#   mypilot.example.com -> Caddy automatically obtains + renews TLS for that domain
# When you set this to a domain (TLS), also set COOKIE_SECURE=1 below.
MYPILOT_CADDY_SITE=:80

# Set to "1" only when serving over HTTPS (sets the Secure flag on cookies).
COOKIE_SECURE=0

# Published Caddy ports. Defaults are 80/443. On rootless hosts that cannot bind low
# ports, set these to e.g. 8080/8443 (then browse to http://localhost:8080).
MYPILOT_HTTP_PORT=80
MYPILOT_HTTPS_PORT=443

# --- Postgres -----------------------------------------------------------------
POSTGRES_DB=mypilot
POSTGRES_USER=mypilot
POSTGRES_PASSWORD=CHANGE_ME_postgres

# --- Object storage (where drive video + route/log artifacts land) ------------
# By default everything is stored in the bundled MinIO container (volume mypilot_minio).
MINIO_ROOT_USER=mypilot
MINIO_ROOT_PASSWORD=CHANGE_ME_minio
S3_BUCKET=mypilot
# To store drive video elsewhere (a bigger disk / external S3 / network store), point these at it.
# Leave them unset to use the bundled MinIO. For external S3 set all three:
#S3_ENDPOINT=https://s3.us-east-1.amazonaws.com
#S3_ACCESS_KEY=your-access-key
#S3_SECRET_KEY=your-secret-key
# (To just relocate the bundled MinIO's data to another disk, change the mypilot_minio volume
#  mapping in compose.override.yaml instead.)

# --- API ----------------------------------------------------------------------
# Used to sign/verify session + CSRF tokens. Keep secret; rotating logs everyone out.
API_SECRET_KEY=CHANGE_ME_secret_key

# --- Web ----------------------------------------------------------------------
# Internal URL the SvelteKit server uses for server-side API calls (SSR auth guard).
# The browser always talks to the same origin under /api (proxied by Caddy).
INTERNAL_API_URL=http://mypilot-api:8000
PUBLIC_API_BASE=/api

# Source repo for the docs wiki's "../" links (e.g. ../mypilot-mici/). Point this at YOUR fork so
# those links resolve on your wiki. Defaults to https://github.com/castanley/mypilot.
MYPILOT_SOURCE_URL=https://github.com/castanley/mypilot
